{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Jellyfin (Testy Debug)",
      "type": "coreclr",
      "request": "launch",
      "program": "${config:jellyfinServerExe}",
      "args": [
        "--datadir",
