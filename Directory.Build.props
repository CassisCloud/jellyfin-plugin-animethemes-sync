<Project>
    <PropertyGroup>
        <Version Condition="'$(Version)' == ''">2.1.0</Version>
        <AssemblyVersion Condition="'$(AssemblyVersion)' == ''">2.1.0.0</AssemblyVersion>
        <FileVersion Condition="'$(FileVersion)' == ''">2.1.0.0</FileVersion>
        <InformationalVersion Condition="'$(InformationalVersion)' == ''">$(Version)</InformationalVersion>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>
        <Deterministic>true</Deterministic>
        <ContinuousIntegrationBuild Condition="'$(GITHUB_ACTIONS)' == 'true'">true</ContinuousIntegrationBuild>
        <DefaultItemExcludes>$(DefaultItemExcludes);artifacts/**</DefaultItemExcludes>
    </PropertyGroup>
</Project>
